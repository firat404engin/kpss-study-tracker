@page
@model ErrorModel
@{
    ViewData["Title"] = "Hata";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <div class="text-center">
            <div class="mx-auto h-16 w-16 bg-red-100 dark:bg-red-900 rounded-full flex items-center justify-center">
                <i class="bi bi-exclamation-triangle-fill text-red-600 text-2xl"></i>
            </div>
            <h1 class="mt-6 text-3xl font-bold text-red-600 dark:text-red-400">Hata!</h1>
            <h2 class="mt-2 text-lg text-gray-600 dark:text-gray-400">İsteğiniz işlenirken bir hata oluştu.</h2>
        </div>
        
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            @if (Model.ShowRequestId)
            {
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">İstek ID:</label>
                    <code class="text-sm bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded">@Model.RequestId</code>
                </div>
            }
            
            <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Geliştirme Modu</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
                    <strong>Geliştirme</strong> ortamına geçiş yaparak oluşan hata hakkında detaylı bilgi görüntüleyebilirsiniz.
                </p>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
                    <strong>Geliştirme ortamı dağıtılan uygulamalar için etkinleştirilmemelidir.</strong>
                    Bu durum, istisnalardan gelen hassas bilgilerin son kullanıcılara görüntülenmesine neden olabilir.
                </p>
                <p class="text-sm text-gray-600 dark:text-gray-400">
                    Yerel hata ayıklama için <strong>ASPNETCORE_ENVIRONMENT</strong> ortam değişkenini <strong>Development</strong> olarak ayarlayın ve uygulamayı yeniden başlatın.
                </p>
            </div>
            
            <div class="mt-6 text-center">
                <a href="/" class="bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg transition-colors inline-flex items-center">
                    <i class="bi bi-house-fill mr-2"></i>Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>