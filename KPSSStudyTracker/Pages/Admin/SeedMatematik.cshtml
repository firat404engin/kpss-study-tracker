@page
@model KPSSStudyTracker.Pages.Admin.SeedMatematikModel
@{
    ViewData["Title"] = "Matematik Konularını Ekle";
}

<div class="container mx-auto px-4 py-8">
    <h2 class="text-3xl font-bold text-blue-600 dark:text-blue-400 mb-6 flex items-center">
        <i class="bi bi-database-fill mr-3"></i>Matematik Konularını Ekle
    </h2>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 max-w-4xl mx-auto">
        @if (Model.SuccessMessage != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                <i class="bi bi-check-circle mr-2"></i>@Model.SuccessMessage
            </div>
        }

        @if (Model.ErrorMessage != null)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <i class="bi bi-exclamation-triangle mr-2"></i>@Model.ErrorMessage
            </div>
        }

        <div class="mb-6">
            <h3 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-4">Mevcut Durum</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-blue-50 dark:bg-blue-900 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">@Model.MatematikDersId</div>
                    <div class="text-sm text-blue-600 dark:text-blue-400">Matematik Ders ID</div>
                </div>
                <div class="bg-green-50 dark:bg-green-900 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-green-600 dark:text-green-400">@Model.MevcutKonuSayisi</div>
                    <div class="text-sm text-green-600 dark:text-green-400">Mevcut Konu Sayısı</div>
                </div>
                <div class="bg-purple-50 dark:bg-purple-900 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">15</div>
                    <div class="text-sm text-purple-600 dark:text-purple-400">Hedef Konu Sayısı</div>
                </div>
            </div>
        </div>

        <form method="post" asp-page-handler="SeedMatematik">
            <div class="flex justify-center">
                <button type="submit" class="bg-primary-600 hover:bg-primary-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
                    <i class="bi bi-database-fill mr-2"></i>Matematik Konularını Ekle (@(15 - Model.MevcutKonuSayisi) konu eklenecek)
                </button>
            </div>
        </form>

        @if (Model.MevcutKonular.Any())
        {
            <div class="mt-8">
                <h3 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-4">Mevcut Konular</h3>
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 max-h-60 overflow-y-auto">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                        @foreach (var konu in Model.MevcutKonular)
                        {
                            <div class="text-sm text-gray-600 dark:text-gray-300">@konu.Title</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>



