@page
@model KPSSStudyTracker.Pages.StudyPlan.IndexModel
@{
    ViewData["Title"] = "Çalışma Planı";
}

<!-- Modern Gradient Background -->
<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900">
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-blue-200 dark:bg-blue-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-purple-200 dark:bg-purple-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse" style="animation-delay: 2s;"></div>
        <div class="absolute top-40 left-1/2 w-60 h-60 bg-pink-200 dark:bg-pink-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse" style="animation-delay: 4s;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <form id="anti" method="post" class="hidden">
            @Html.AntiForgeryToken()
        </form>
        <!-- Modern Header -->
        <div class="text-center mb-12">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl mb-6 shadow-lg">
                <i class="bi bi-calendar-week text-white text-3xl"></i>
            </div>
            <h1 class="text-4xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent mb-4">
                KPSS 2026 Çalışma Planı
            </h1>
            <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto">
                Haftalık konu bitirme programınızı takip edin ve hedeflerinize ulaşın
            </p>
            <div class="flex items-center justify-center gap-4 mt-6">
                <form method="post" asp-page-handler="Regenerate" class="inline flex items-center gap-3">
                    @Html.AntiForgeryToken()
                    <input type="number" name="startWeek" min="1" max="52" value="1" class="w-20 px-3 py-3 bg-white/70 dark:bg-slate-700/70 border border-gray-200/50 dark:border-slate-600/50 rounded-xl text-center" title="Başlangıç Haftası" />
                    <input type="number" name="topicsPerDay" min="1" max="15" value="5" class="w-20 px-3 py-3 bg-white/70 dark:bg-slate-700/70 border border-gray-200/50 dark:border-slate-600/50 rounded-xl text-center" title="Günlük Konu" />
                    <button type="submit" class="group inline-flex items-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white rounded-2xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                        <i class="bi bi-magic mr-3 text-xl group-hover:scale-110 transition-transform"></i>Planı Baştan Oluştur
                    </button>
                </form>
                <form method="post" asp-page-handler="ClearAll" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="group inline-flex items-center px-6 py-4 bg-gradient-to-r from-rose-500 to-red-600 hover:from-rose-600 hover:to-red-700 text-white rounded-2xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" onclick="return confirm('Tüm mevcut çalışma programlarını silmek istediğinize emin misiniz?');">
                        <i class="bi bi-trash3 mr-3 text-xl group-hover:scale-110 transition-transform"></i>Tüm Programları Sil
                    </button>
                </form>
            </div>
        </div>

        <!-- Progress Overview Card -->
        <div class="backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 rounded-3xl shadow-2xl border border-white/20 dark:border-slate-700/30 p-8 mb-8">
            <div class="text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-r from-green-500 to-emerald-500 rounded-full mb-4">
                    <i class="bi bi-graph-up-arrow text-white text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Genel İlerleme</h3>
                <div class="text-5xl font-extrabold bg-gradient-to-r from-green-600 to-emerald-600 bg-clip-text text-transparent mb-4">%@Model.OverallProgress</div>
                
                <div class="max-w-md mx-auto mb-6">
                    <div class="w-full bg-gray-200 dark:bg-gray-600 rounded-full h-4 shadow-inner">
                        <div class="bg-gradient-to-r from-green-500 to-emerald-500 h-4 rounded-full transition-all duration-1000 ease-out shadow-lg" style="width: @Model.OverallProgress%"></div>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-4 max-w-sm mx-auto">
                    <div class="bg-gradient-to-r from-green-100 to-emerald-100 dark:from-green-900/30 dark:to-emerald-900/30 rounded-2xl p-4">
                        <div class="text-2xl font-bold text-green-700 dark:text-green-300">@Model.CompletedCount</div>
                        <div class="text-sm text-green-600 dark:text-green-400">Tamamlandı</div>
                    </div>
                    <div class="bg-gradient-to-r from-blue-100 to-indigo-100 dark:from-blue-900/30 dark:to-indigo-900/30 rounded-2xl p-4">
                        <div class="text-2xl font-bold text-blue-700 dark:text-blue-300">@Model.TotalCount</div>
                        <div class="text-sm text-blue-600 dark:text-blue-400">Toplam</div>
                    </div>
                </div>
            </div>
        </div>

        

        <!-- Weekly Study Plan -->
        <div class="space-y-8">
            @foreach (var week in Model.StudyPlanByWeek)
            {
                <div class="backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 rounded-3xl shadow-2xl border border-white/20 dark:border-slate-700/30 overflow-hidden">
                    <!-- Week Header -->
                    <div class="bg-gradient-to-r from-emerald-500 to-teal-600 px-8 py-6">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center">
                                <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mr-4 backdrop-blur-sm">
                                    <i class="bi bi-calendar-week text-white text-xl"></i>
                                </div>
                                <div>
                                    <h3 class="text-2xl font-bold text-white">Hafta @week.Key</h3>
                                    <p class="text-white/80 text-sm">Çalışma Programı</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="text-white/90 text-sm mb-1">İlerleme</div>
                                <div class="text-3xl font-bold text-white">%@week.Value.Progress</div>
                                <div class="w-32 bg-white/20 rounded-full h-2 mt-2">
                                    <div class="bg-white h-2 rounded-full transition-all duration-1000" style="width: @week.Value.Progress%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Days Grid -->
                    <div class="p-8">
                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                            @foreach (var day in week.Value.Days)
                            {
                                <div class="bg-gradient-to-br from-white/60 to-white/40 dark:from-slate-700/60 dark:to-slate-600/40 rounded-2xl p-6 border border-white/30 dark:border-slate-600/30 backdrop-blur-sm hover:shadow-xl transition-all duration-300">
                                    <div class="flex items-center justify-between mb-6">
                                        <div class="flex items-center">
                                            <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-purple-500 rounded-xl flex items-center justify-center mr-3">
                                                <i class="bi bi-calendar-day text-white text-lg"></i>
                                            </div>
                                            <h4 class="text-lg font-bold text-gray-900 dark:text-white">Gün @day.Key</h4>
                                        </div>
                                        @if (day.Value.IsCompleted)
                                        {
                                            <div class="flex items-center px-3 py-1 bg-gradient-to-r from-green-100 to-emerald-100 dark:from-green-900/30 dark:to-emerald-900/30 rounded-full">
                                                <i class="bi bi-check-circle-fill text-green-600 dark:text-green-400 mr-2"></i>
                                                <span class="text-sm font-semibold text-green-700 dark:text-green-300">Tamamlandı</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="flex items-center px-3 py-1 bg-gradient-to-r from-yellow-100 to-orange-100 dark:from-yellow-900/30 dark:to-orange-900/30 rounded-full">
                                                <i class="bi bi-clock-fill text-yellow-600 dark:text-yellow-400 mr-2"></i>
                                                <span class="text-sm font-semibold text-yellow-700 dark:text-yellow-300">Bekliyor</span>
                                            </div>
                                        }
                                    </div>
                                    
                                    <div class="space-y-4">
                                        @foreach (var item in day.Value.Items)
                                        {
                                            <div class="flex items-start space-x-4 p-4 bg-white/50 dark:bg-slate-600/50 rounded-xl border border-white/30 dark:border-slate-500/30 hover:shadow-md transition-all duration-200">
                                                <div class="flex-shrink-0 mt-1">
                                                    <input type="checkbox" 
                                                           @(item.IsCompleted ? "checked" : "") 
                                                           onchange="toggleCompletion(@item.Id, this.checked)"
                                                           class="w-5 h-5 text-emerald-600 bg-white border-gray-300 rounded-lg focus:ring-emerald-500 dark:focus:ring-emerald-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600 transition-all duration-200">
                                                </div>
                                                <div class="flex-1 min-w-0">
                                                    <div class="flex items-center mb-2">
                                                        <div class="w-6 h-6 bg-gradient-to-r from-blue-500 to-purple-500 rounded-lg flex items-center justify-center mr-2">
                                                            <i class="bi bi-book text-white text-xs"></i>
                                                        </div>
                                                        <div class="text-sm font-bold text-gray-900 dark:text-white truncate">@item.LessonName</div>
                                                    </div>
                                                    <div class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">@item.TopicTitle</div>
                                                    @if (!string.IsNullOrEmpty(item.Source))
                                                    {
                                                        <div class="mt-2 flex items-center text-xs text-gray-500 dark:text-gray-500">
                                                            <i class="bi bi-source mr-1"></i>
                                                            <span>@item.Source</span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.StudyPlanByWeek.Any())
        {
            <div class="backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 rounded-3xl shadow-2xl border border-white/20 dark:border-slate-700/30 p-12 text-center">
                <div class="w-20 h-20 bg-gradient-to-r from-gray-400 to-gray-500 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="bi bi-calendar-x text-white text-3xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Filtreye Uygun Plan Bulunamadı</h3>
                <p class="text-gray-600 dark:text-gray-400 text-lg mb-6">Farklı filtreler deneyerek daha fazla sonuç görebilirsiniz</p>
                <a href="/StudyPlan" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl">
                    <i class="bi bi-arrow-clockwise mr-2"></i>Filtreleri Temizle
                </a>
            </div>
        }
    </div>
</div>

<script>
    async function toggleCompletion(id, isCompleted) {
        try {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : '';
            const response = await fetch('/StudyPlan?handler=ToggleCompletion', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ id: id, isCompleted: isCompleted })
            });
            
            if (response.ok) {
                // Smooth reload with animation
                setTimeout(() => {
                    location.reload();
                }, 300);
            } else {
                alert('Bir hata oluştu. Lütfen tekrar deneyin.');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Bir hata oluştu. Lütfen tekrar deneyin.');
        }
    }
</script>
