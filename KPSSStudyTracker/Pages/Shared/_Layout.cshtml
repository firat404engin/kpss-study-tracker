<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KPSS Çalışma Takip</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 transition-colors duration-300 min-h-screen flex flex-col">
    <!-- Modern Glass Navbar -->
    <header class="backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 shadow-lg border-b border-white/20 dark:border-slate-700/30 sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <!-- Logo / Brand -->
                <div class="flex-shrink-0">
                    <a href="/" class="group flex items-center gap-3 text-xl sm:text-2xl font-extrabold bg-gradient-to-r from-fuchsia-600 to-cyan-600 bg-clip-text text-transparent transition-all duration-300">
                        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-r from-fuchsia-500 to-cyan-500 rounded-2xl flex items-center justify-center shadow-lg group-hover:shadow-xl group-hover:scale-105 transition-all duration-300">
                            <i class="bi bi-intersect text-white text-lg sm:text-xl"></i>
                        </div>
                        <span class="hidden md:block tracking-tight">MUHENDİSDİSİPLİNİ</span>
                    </a>
                </div>
                
                <!-- Desktop Navigation -->
                <div class="hidden lg:flex items-center gap-2 overflow-x-auto no-scrollbar">
                    <a href="/" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-700 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition text-sm whitespace-nowrap">
                        <i class="bi bi-house-fill"></i>
                        <span>Ana Sayfa</span>
                    </a>
                    <a href="/StudyScheduler/View" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-gradient-to-r from-purple-500/20 to-pink-500/20 dark:from-purple-700/40 dark:to-pink-700/40 text-purple-700 dark:text-purple-300 hover:from-purple-500/30 hover:to-pink-500/30 transition text-sm whitespace-nowrap">
                        <i class="bi bi-calendar-range-fill"></i>
                        <span>Program</span>
                    </a>
                    <a href="/Todo" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-700 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition text-sm whitespace-nowrap">
                        <i class="bi bi-check2-square"></i>
                        <span>Todo</span>
                    </a>
                    <a href="/Lessons" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-700 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition text-sm whitespace-nowrap">
                        <i class="bi bi-book-fill"></i>
                        <span>Dersler</span>
                    </a>
                    <a href="/Distributions" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-700 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition text-sm whitespace-nowrap">
                        <i class="bi bi-table"></i>
                        <span>Soru Dağılımı</span>
                    </a>
                    <a href="/Statistics" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-700 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition text-sm whitespace-nowrap">
                        <i class="bi bi-graph-up"></i>
                        <span>İstatistik</span>
                    </a>
                    <a href="/Exams" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-700 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition text-sm whitespace-nowrap">
                        <i class="bi bi-clipboard-check-fill"></i>
                        <span>Deneme</span>
                    </a>
                </div>
                
                <!-- Right Side -->
                <div class="flex items-center gap-2">
                    <!-- Theme Toggle -->
                    <button id="themeToggle" class="p-2 sm:p-3 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-600 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition-all">
                        <i class="bi bi-sun-fill dark:hidden"></i>
                        <i class="bi bi-moon-fill hidden dark:block"></i>
                    </button>
                    
                    <!-- Mobile Menu Button -->
                    <button id="mobileMenuButton" class="lg:hidden p-2 sm:p-3 rounded-xl bg-white/60 dark:bg-slate-700/60 text-gray-600 dark:text-gray-300 hover:bg-white/80 dark:hover:bg-slate-700/80 transition-all">
                        <i class="bi bi-list text-xl"></i>
                    </button>
                    
                    <!-- User Menu -->
                    <div class="hidden sm:flex items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="text-xs px-3 py-2 bg-white/60 dark:bg-slate-700/60 rounded-xl text-gray-600 dark:text-gray-400">@User.Identity?.Name</span>
                            <form method="post" asp-page="/Account/Logout" class="inline">
                                <button type="submit" class="inline-flex items-center gap-1 px-3 py-2 text-xs rounded-xl bg-gradient-to-r from-rose-500 to-red-600 text-white hover:from-rose-600 hover:to-red-700 transition-all">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Çıkış</span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <a href="/Account/Login" class="px-3 py-2 text-xs bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl hover:from-blue-600 hover:to-indigo-700 transition-all">
                                <i class="bi bi-box-arrow-in-right mr-1"></i>Giriş
                            </a>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Mobile Menu -->
            <div id="mobileMenu" class="lg:hidden hidden pb-4">
                <div class="space-y-2">
                    <a href="/" class="flex items-center px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/60 dark:hover:bg-slate-700/60 transition-all">
                        <i class="bi bi-house-fill mr-3 text-lg"></i>
                        <span class="font-medium">Ana Sayfa</span>
                    </a>
                    <a href="/StudyScheduler/View" class="flex items-center px-4 py-3 rounded-xl bg-gradient-to-r from-purple-500/20 to-pink-500/20 text-purple-700 dark:text-purple-300 transition-all">
                        <i class="bi bi-calendar-range-fill mr-3 text-lg"></i>
                        <span class="font-medium">Çalışma Programı</span>
                    </a>
                    <a href="/Todo" class="flex items-center px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/60 dark:hover:bg-slate-700/60 transition-all">
                        <i class="bi bi-check2-square mr-3 text-lg"></i>
                        <span class="font-medium">Todo Listesi</span>
                    </a>
                    <a href="/Lessons" class="flex items-center px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/60 dark:hover:bg-slate-700/60 transition-all">
                        <i class="bi bi-book-fill mr-3 text-lg"></i>
                        <span class="font-medium">Dersler</span>
                    </a>
                    <a href="/Distributions" class="flex items-center px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/60 dark:hover:bg-slate-700/60 transition-all">
                        <i class="bi bi-table mr-3 text-lg"></i>
                        <span class="font-medium">Soru Dağılımı</span>
                    </a>
                    <a href="/Exams" class="flex items-center px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/60 dark:hover:bg-slate-700/60 transition-all">
                        <i class="bi bi-clipboard-check-fill mr-3 text-lg"></i>
                        <span class="font-medium">Denemeler</span>
                    </a>
                    <a href="/Statistics" class="flex items-center px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/60 dark:hover:bg-slate-700/60 transition-all">
                        <i class="bi bi-graph-up mr-3 text-lg"></i>
                        <span class="font-medium">İstatistikler</span>
                    </a>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form method="post" asp-page="/Account/Logout" class="mt-4">
                            <button type="submit" class="w-full flex items-center px-4 py-3 rounded-xl bg-gradient-to-r from-rose-500 to-red-600 text-white hover:from-rose-600 hover:to-red-700 transition-all">
                                <i class="bi bi-box-arrow-right mr-3 text-lg"></i>
                                <span class="font-medium">Çıkış Yap</span>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-1">
        @RenderBody()
    </main>

    <!-- Modern Footer -->
    <footer class="backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border-t border-white/20 dark:border-slate-700/30 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Brand Section -->
                <div class="text-center md:text-left">
                    <div class="flex items-center justify-center md:justify-start mb-4">
                        <div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg mr-3">
                            <i class="bi bi-book-fill text-white text-xl"></i>
                        </div>
                        <h3 class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">KPSS Çalışma Takip</h3>
                    </div>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                        KPSS 2026 sınavına hazırlık sürecinizi organize edin, ilerlemenizi takip edin ve hedeflerinize ulaşın.
                    </p>
                </div>
                
                <!-- Quick Links -->
                <div class="text-center">
                    <h4 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Hızlı Erişim</h4>
                    <div class="space-y-2">
                        <a href="/" class="block text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                            <i class="bi bi-house-fill mr-2"></i>Gösterge Paneli
                        </a>
                        <a href="/Todo" class="block text-gray-600 dark:text-gray-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors">
                            <i class="bi bi-check2-square mr-2"></i>Todo
                        </a>
                        <a href="/Distributions" class="block text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
                            <i class="bi bi-table mr-2"></i>Soru Dağılımları
                        </a>
                        <a href="/Lessons" class="block text-gray-600 dark:text-gray-400 hover:text-green-600 dark:hover:text-green-400 transition-colors">
                            <i class="bi bi-book-fill mr-2"></i>Dersler
                        </a>
                        <a href="/Exams" class="block text-gray-600 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors">
                            <i class="bi bi-clipboard-check-fill mr-2"></i>Denemeler
                        </a>
                    </div>
                </div>
                
                <!-- Developer Info -->
                <div class="text-center md:text-right">
                    <h4 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Geliştirici</h4>
                    <div class="space-y-3">
                        <a href="https://firatengincv.vercel.app/tr" target="_blank" class="group inline-flex items-center justify-center md:justify-end px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white rounded-xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                            <i class="bi bi-person-fill mr-2 group-hover:scale-110 transition-transform"></i>
                            <span>Fırat Engin</span>
                            <i class="bi bi-box-arrow-up-right ml-2 group-hover:scale-110 transition-transform"></i>
                        </a>
                        <div class="flex justify-center md:justify-end space-x-4">
                            <a href="https://github.com/firat404engin" target="_blank" class="group p-2 bg-gray-100 dark:bg-gray-700 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 transition-all duration-200" title="GitHub">
                                <i class="bi bi-github text-gray-600 dark:text-gray-400 group-hover:scale-110 transition-transform"></i>
                            </a>
                            <a href="https://www.linkedin.com/in/firatengin404/" target="_blank" class="group p-2 bg-gray-100 dark:bg-gray-700 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 transition-all duration-200" title="LinkedIn">
                                <i class="bi bi-linkedin text-gray-600 dark:text-gray-400 group-hover:scale-110 transition-transform"></i>
                            </a>
                            <a href="https://www.instagram.com/firatengin404/" target="_blank" class="group p-2 bg-gray-100 dark:bg-gray-700 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 transition-all duration-200" title="Instagram">
                                <i class="bi bi-instagram text-gray-600 dark:text-gray-400 group-hover:scale-110 transition-transform"></i>
                            </a>
                            <a href="mailto:fengin7321@gmail.com" class="group p-2 bg-gray-100 dark:bg-gray-700 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 transition-all duration-200" title="E-posta">
                                <i class="bi bi-envelope-fill text-gray-600 dark:text-gray-400 group-hover:scale-110 transition-transform"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Bottom Bar -->
            <div class="border-t border-gray-200/50 dark:border-slate-700/50 mt-8 pt-6">
                <div class="flex flex-col md:flex-row justify-between items-center space-y-2 md:space-y-0">
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                        &copy; 2024 KPSS Çalışma Takip Sistemi. Tüm hakları saklıdır.
                    </p>
                    <p class="text-sm text-gray-500 dark:text-gray-500">
                        <span class="text-blue-600 dark:text-blue-400 font-semibold">Fırat Engin</span> tarafından geliştirilmiştir.
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Dark mode toggle
        document.addEventListener('DOMContentLoaded', () => {
            const themeToggle = document.getElementById('themeToggle');
            const mobileMenuButton = document.getElementById('mobileMenuButton');
            const mobileMenu = document.getElementById('mobileMenu');
            const currentTheme = localStorage.getItem('theme');

            if (currentTheme === 'dark') {
                document.documentElement.classList.add('dark');
            }

            themeToggle.addEventListener('click', () => {
                document.documentElement.classList.toggle('dark');
                const isDark = document.documentElement.classList.contains('dark');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });

            // Mobile menu toggle
            mobileMenuButton.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });

            // Close mobile menu when clicking outside
            document.addEventListener('click', (e) => {
                if (!mobileMenuButton.contains(e.target) && !mobileMenu.contains(e.target)) {
                    mobileMenu.classList.add('hidden');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>