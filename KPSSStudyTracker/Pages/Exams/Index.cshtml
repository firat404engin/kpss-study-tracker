@page
@model KPSSStudyTracker.Pages.Exams.IndexModel
@{
    ViewData["Title"] = "Denemeler";
}

<!-- Modern Gradient Background -->
<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900">
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-blue-200 dark:bg-blue-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-purple-200 dark:bg-purple-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse" style="animation-delay: 2s;"></div>
        <div class="absolute top-40 left-1/2 w-60 h-60 bg-pink-200 dark:bg-pink-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse" style="animation-delay: 4s;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Modern Header -->
        <div class="text-center mb-12">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-r from-blue-500 to-purple-600 rounded-2xl mb-6 shadow-lg">
                <i class="bi bi-clipboard-check-fill text-white text-3xl"></i>
            </div>
            <h1 class="text-4xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent mb-4">
                Deneme Sınavları
            </h1>
            <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto mb-8">
                Deneme sınavı sonuçlarınızı görüntüleyin ve KPSS P3 puanlarınızı analiz edin
            </p>
            <a href="/Exams/Create" class="group inline-flex items-center px-8 py-4 bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white rounded-2xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                <i class="bi bi-plus-circle-fill mr-3 text-xl group-hover:scale-110 transition-transform"></i>Yeni Deneme Ekle
            </a>
        </div>

        <!-- Success/Error Messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 border border-green-200/50 dark:border-green-700/50 rounded-2xl p-4 backdrop-blur-sm">
                <div class="flex items-center">
                    <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mr-3">
                        <i class="bi bi-check-circle-fill text-green-600 dark:text-green-400 text-lg"></i>
                    </div>
                    <p class="text-green-800 dark:text-green-200 font-semibold">@TempData["SuccessMessage"]</p>
                </div>
            </div>
        }
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 bg-gradient-to-r from-red-50 to-pink-50 dark:from-red-900/20 dark:to-pink-900/20 border border-red-200/50 dark:border-red-700/50 rounded-2xl p-4 backdrop-blur-sm">
                <div class="flex items-center">
                    <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mr-3">
                        <i class="bi bi-exclamation-triangle-fill text-red-600 dark:text-red-400 text-lg"></i>
                    </div>
                    <p class="text-red-800 dark:text-red-200 font-semibold">@TempData["ErrorMessage"]</p>
                </div>
            </div>
        }

        <!-- Modern Glass Card -->
        <div class="backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 rounded-3xl shadow-2xl border border-white/20 dark:border-slate-700/30 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200/50 dark:divide-slate-700/50">
                    <thead class="bg-gradient-to-r from-blue-50/50 to-purple-50/50 dark:from-blue-900/20 dark:to-purple-900/20">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-calendar3 mr-2 text-blue-500"></i>Tarih
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-file-text mr-2 text-purple-500"></i>Deneme Adı
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-graph-up-arrow mr-2 text-green-500"></i>GY Net
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-bar-chart-line mr-2 text-blue-500"></i>GK Net
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-pie-chart-fill mr-2 text-indigo-500"></i>Toplam Net
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-trophy-fill mr-2 text-amber-500"></i>Tahmini KPSS P3
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-gear-fill mr-2 text-gray-500"></i>İşlemler
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white/50 dark:bg-slate-800/50 divide-y divide-gray-200/30 dark:divide-slate-700/30">
                        @foreach (var e in Model.Exams)
                        {
                            var estimatedKpssScore = e.P3Score;
                            <tr class="hover:bg-white/70 dark:hover:bg-slate-700/70 transition-all duration-200">
                                <td class="px-6 py-6 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="w-12 h-12 bg-gradient-to-r from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30 rounded-xl flex items-center justify-center mr-4 shadow-lg">
                                            <i class="bi bi-calendar-date text-blue-600 dark:text-blue-400 text-lg"></i>
                                        </div>
                                        <div>
                                            <div class="text-sm font-semibold text-gray-900 dark:text-white">@e.Date.ToString("dd MMMM yyyy")</div>
                                            <div class="text-xs text-gray-500 dark:text-gray-400">@e.Date.ToString("dddd")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap">
                                    <div class="text-sm font-semibold text-gray-900 dark:text-white">@e.Name</div>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-sm font-bold @(e.GyNet >= 30 ? "bg-gradient-to-r from-green-100 to-green-200 text-green-800 dark:from-green-900/30 dark:to-green-800/30 dark:text-green-300" : e.GyNet >= 20 ? "bg-gradient-to-r from-yellow-100 to-yellow-200 text-yellow-800 dark:from-yellow-900/30 dark:to-yellow-800/30 dark:text-yellow-300" : "bg-gradient-to-r from-red-100 to-red-200 text-red-800 dark:from-red-900/30 dark:to-red-800/30 dark:text-red-300") shadow-lg">
                                        @Math.Round(e.GyNet, 2)
                                    </span>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-sm font-bold @(e.GkNet >= 30 ? "bg-gradient-to-r from-green-100 to-green-200 text-green-800 dark:from-green-900/30 dark:to-green-800/30 dark:text-green-300" : e.GkNet >= 20 ? "bg-gradient-to-r from-yellow-100 to-yellow-200 text-yellow-800 dark:from-yellow-900/30 dark:to-yellow-800/30 dark:text-yellow-300" : "bg-gradient-to-r from-red-100 to-red-200 text-red-800 dark:from-red-900/30 dark:to-red-800/30 dark:text-red-300") shadow-lg">
                                        @Math.Round(e.GkNet, 2)
                                    </span>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-sm font-bold @(e.Net >= 60 ? "bg-gradient-to-r from-green-100 to-green-200 text-green-800 dark:from-green-900/30 dark:to-green-800/30 dark:text-green-300" : e.Net >= 40 ? "bg-gradient-to-r from-yellow-100 to-yellow-200 text-yellow-800 dark:from-yellow-900/30 dark:to-yellow-800/30 dark:text-yellow-300" : "bg-gradient-to-r from-red-100 to-red-200 text-red-800 dark:from-red-900/30 dark:to-red-800/30 dark:text-red-300") shadow-lg">
                                        @Math.Round(e.Net, 2)
                                    </span>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <div class="inline-flex items-center px-4 py-2 rounded-xl bg-gradient-to-r from-amber-100 to-orange-100 dark:from-amber-900/30 dark:to-orange-900/30 shadow-lg">
                                        <i class="bi bi-trophy-fill mr-2 text-amber-600 dark:text-amber-400"></i>
                                        <span class="text-lg font-bold @(estimatedKpssScore >= 75 ? "text-green-600 dark:text-green-400" : estimatedKpssScore >= 60 ? "text-yellow-600 dark:text-yellow-400" : "text-red-600 dark:text-red-400")">
                                            @estimatedKpssScore
                                        </span>
                                    </div>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <div class="flex justify-center space-x-2">
                                        <button class="group p-2 bg-gradient-to-r from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30 hover:from-blue-200 hover:to-blue-300 dark:hover:from-blue-800/50 dark:hover:to-blue-700/50 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" title="Detayları Görüntüle" onclick="showExamDetails(@e.Id, '@Html.Raw(e.Name)', '@e.Date.ToString("dd MMMM yyyy")', @e.GyNet, @e.GkNet, @e.Net, @e.P3Score)">
                                            <i class="bi bi-eye-fill text-blue-600 dark:text-blue-400 group-hover:scale-110 transition-transform"></i>
                                        </button>
                                        <a href="/Exams/Edit/@e.Id" class="group p-2 bg-gradient-to-r from-green-100 to-green-200 dark:from-green-900/30 dark:to-green-800/30 hover:from-green-200 hover:to-green-300 dark:hover:from-green-800/50 dark:hover:to-green-700/50 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" title="Düzenle">
                                            <i class="bi bi-pencil-fill text-green-600 dark:text-green-400 group-hover:scale-110 transition-transform"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@e.Id" class="inline" onsubmit="return confirm('Bu deneme sınavını silmek istediğinizden emin misiniz?')">
                                            <button type="submit" class="group p-2 bg-gradient-to-r from-red-100 to-red-200 dark:from-red-900/30 dark:to-red-800/30 hover:from-red-200 hover:to-red-300 dark:hover:from-red-800/50 dark:hover:to-red-700/50 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" title="Sil">
                                                <i class="bi bi-trash-fill text-red-600 dark:text-red-400 group-hover:scale-110 transition-transform"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        
            @if (!Model.Exams.Any())
            {
                <div class="text-center py-16">
                    <div class="w-24 h-24 bg-gradient-to-r from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-700 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <i class="bi bi-clipboard-check text-gray-400 dark:text-gray-500 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Henüz deneme sınavı eklenmemiş</h3>
                    <p class="text-gray-500 dark:text-gray-400 mb-6 max-w-md mx-auto">İlk deneme sınavınızı ekleyerek KPSS hazırlık sürecinizi takip etmeye başlayın</p>
                    <a href="/Exams/Create" class="group inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white rounded-xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                        <i class="bi bi-plus-circle-fill mr-2 group-hover:scale-110 transition-transform"></i>İlk Denemeyi Ekle
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Exam Details Modal -->
<div id="examDetailsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl max-w-md w-full p-6 transform transition-all duration-300 scale-95 opacity-0" id="modalContent">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">Deneme Sınavı Detayları</h3>
            <button onclick="closeExamDetails()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>
        
        <div class="space-y-4">
            <div class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 rounded-xl p-4">
                <div class="flex items-center mb-2">
                    <i class="bi bi-file-text text-blue-600 dark:text-blue-400 mr-2"></i>
                    <span class="font-semibold text-gray-700 dark:text-gray-300">Deneme Adı</span>
                </div>
                <p class="text-gray-900 dark:text-white" id="modalExamName">-</p>
            </div>
            
            <div class="bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-xl p-4">
                <div class="flex items-center mb-2">
                    <i class="bi bi-calendar-date text-green-600 dark:text-green-400 mr-2"></i>
                    <span class="font-semibold text-gray-700 dark:text-gray-300">Tarih</span>
                </div>
                <p class="text-gray-900 dark:text-white" id="modalExamDate">-</p>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-gradient-to-r from-purple-50 to-pink-50 dark:from-purple-900/20 dark:to-pink-900/20 rounded-xl p-4 text-center">
                    <div class="text-sm font-semibold text-purple-700 dark:text-purple-300 mb-1">GY Net</div>
                    <div class="text-2xl font-bold text-purple-800 dark:text-purple-200" id="modalGyNet">-</div>
                </div>
                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
                    <div class="text-sm font-semibold text-blue-700 dark:text-blue-300 mb-1">GK Net</div>
                    <div class="text-2xl font-bold text-blue-800 dark:text-blue-200" id="modalGkNet">-</div>
                </div>
            </div>
            
            <div class="bg-gradient-to-r from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
                <div class="text-sm font-semibold text-emerald-700 dark:text-emerald-300 mb-1">Toplam Net</div>
                <div class="text-2xl font-bold text-emerald-800 dark:text-emerald-200" id="modalTotalNet">-</div>
            </div>
            
            <div class="bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
                <div class="text-sm font-semibold text-amber-700 dark:text-amber-300 mb-1">Tahmini KPSS P3</div>
                <div class="text-3xl font-bold text-amber-800 dark:text-amber-200" id="modalP3Score">-</div>
            </div>
        </div>
        
        <div class="flex justify-end space-x-3 mt-6">
            <button onclick="closeExamDetails()" class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                Kapat
            </button>
        </div>
    </div>
</div>

<script>
function showExamDetails(id, name, date, gyNet, gkNet, totalNet, p3Score) {
    document.getElementById('modalExamName').textContent = name;
    document.getElementById('modalExamDate').textContent = date;
    document.getElementById('modalGyNet').textContent = gyNet;
    document.getElementById('modalGkNet').textContent = gkNet;
    document.getElementById('modalTotalNet').textContent = totalNet;
    document.getElementById('modalP3Score').textContent = p3Score;
    
    const modal = document.getElementById('examDetailsModal');
    const content = document.getElementById('modalContent');
    
    modal.classList.remove('hidden');
    setTimeout(() => {
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');
    }, 10);
}

function closeExamDetails() {
    const modal = document.getElementById('examDetailsModal');
    const content = document.getElementById('modalContent');
    
    content.classList.remove('scale-100', 'opacity-100');
    content.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
        modal.classList.add('hidden');
    }, 300);
}

// Modal dışına tıklandığında kapat
document.getElementById('examDetailsModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeExamDetails();
    }
});

// ESC tuşu ile kapat
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closeExamDetails();
    }
});
</script>