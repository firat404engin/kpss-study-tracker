<script>
    const tabs = document.querySelectorAll('.dist-tab');
    const sections = document.querySelectorAll('section[data-section]');
    function activate(target){
        sections.forEach(s=>{ s.classList.toggle('hidden', s.getAttribute('data-section')!==target); });
        tabs.forEach(b=>{
            const on = b.getAttribute('data-target')===target;
            b.classList.toggle('active', on);
            if(on){
                b.className = 'dist-tab active px-4 py-2 rounded-xl text-sm font-medium bg-white/80 dark:bg-slate-800/80 text-indigo-700 dark:text-indigo-300 border border-indigo-200/60 dark:border-slate-700 shadow hover:shadow-md transition';
            } else {
                b.className = 'dist-tab px-4 py-2 rounded-xl text-sm font-medium bg-white/70 dark:bg-slate-800/60 text-slate-700 dark:text-slate-300 border border-gray-200/60 dark:border-slate-700 hover:shadow-md transition';
            }
        });
    }
    tabs.forEach(t=> t.addEventListener('click', ()=> activate(t.getAttribute('data-target'))));
    // default
    activate('turkce');
</script>
