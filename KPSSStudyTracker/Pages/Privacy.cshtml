@page
@model PrivacyModel
@{
    ViewData["Title"] = "Gizlilik Politikası";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
            <i class="bi bi-shield-check text-primary-600 mr-2"></i>Gizlilik Politikası
        </h1>
        <p class="text-gray-600 dark:text-gray-400">Verilerinizin nasıl korunduğu hakkında bilgi</p>
    </div>

    <!-- Content -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
        <div class="prose dark:prose-invert max-w-none">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Veri Toplama ve Kullanım</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-6">
                KPSS Çalışma Takip uygulaması, çalışma verilerinizi yerel olarak saklar ve işler. 
                Toplanan veriler sadece kişisel çalışma takibiniz için kullanılır.
            </p>

            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Saklanan Veriler</h2>
            <ul class="list-disc list-inside text-gray-600 dark:text-gray-400 mb-6 space-y-2">
                <li>Ders ve konu bilgileri</li>
                <li>Çözülen soru sayıları ve doğruluk oranları</li>
                <li>Deneme sınavı sonuçları</li>
                <li>Motivasyon sözleri ve notlar</li>
                <li>Kullanıcı hesap bilgileri (şifreler şifrelenmiş olarak saklanır)</li>
            </ul>

            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Veri Güvenliği</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-6">
                Tüm verileriniz yerel SQL Server veritabanında güvenli bir şekilde saklanır. 
                Şifreler BCrypt algoritması ile şifrelenir ve hiçbir zaman düz metin olarak saklanmaz.
            </p>

            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Veri Paylaşımı</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-6">
                Verileriniz üçüncü taraflarla paylaşılmaz. Tüm veriler yerel olarak saklanır ve 
                sadece sizin erişiminiz altındadır.
            </p>

            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Yedekleme ve İçe Aktarma</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-6">
                Verilerinizi JSON veya CSV formatında yedekleyebilir ve geri yükleyebilirsiniz. 
                Bu işlemler tamamen yerel olarak gerçekleştirilir.
            </p>

            <div class="bg-blue-50 dark:bg-blue-900 rounded-lg p-4 mt-8">
                <div class="flex items-start">
                    <i class="bi bi-info-circle-fill text-blue-600 text-xl mr-3 mt-0.5"></i>
                    <div>
                        <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-2">Önemli Not</h3>
                        <p class="text-sm text-blue-800 dark:text-blue-200">
                            Bu uygulama tamamen yerel olarak çalışır ve verileriniz internet üzerinden paylaşılmaz. 
                            Tüm verileriniz bilgisayarınızda güvenli bir şekilde saklanır.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>