@page
@model KPSSStudyTracker.Pages.Lessons.IndexModel
@{
    ViewData["Title"] = "Dersler";
}

<!-- Modern Gradient Background -->
<div class="min-h-screen bg-gradient-to-br from-slate-50 via-emerald-50 to-teal-100 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900">
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-emerald-200 dark:bg-emerald-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-teal-200 dark:bg-teal-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse" style="animation-delay: 2s;"></div>
        <div class="absolute top-40 left-1/2 w-60 h-60 bg-green-200 dark:bg-green-800 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-30 animate-pulse" style="animation-delay: 4s;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Modern Header -->
        <div class="text-center mb-12">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl mb-6 shadow-lg">
                <i class="bi bi-book-fill text-white text-3xl"></i>
            </div>
            <h1 class="text-4xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent mb-4">
                KPSS Dersleri
            </h1>
            <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto mb-8">
                KPSS derslerinizi ve konularınızı yönetin, ilerlemenizi takip edin
            </p>
            @if (Model.IsAdmin)
            {
            <a href="/Lessons/Create" class="group inline-flex items-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white rounded-2xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                <i class="bi bi-plus-circle-fill mr-3 text-xl group-hover:scale-110 transition-transform"></i>Yeni Ders Ekle
            </a>
            }
        </div>

        <!-- Modern Glass Card -->
        <div class="backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 rounded-3xl shadow-2xl border border-white/20 dark:border-slate-700/30 overflow-hidden">
            <!-- Desktop Table View -->
            <div class="hidden lg:block overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200/50 dark:divide-slate-700/50">
                    <thead class="bg-gradient-to-r from-emerald-50/50 to-teal-50/50 dark:from-emerald-900/20 dark:to-teal-900/20">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-book-fill mr-2 text-emerald-500"></i>Ders Adı
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-list-ul mr-2 text-blue-500"></i>Toplam Konu
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-check-circle-fill mr-2 text-green-500"></i>Tamamlanan
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-graph-up-arrow mr-2 text-purple-500"></i>İlerleme
                            </th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                                <i class="bi bi-gear-fill mr-2 text-gray-500"></i>İşlemler
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white/50 dark:bg-slate-800/50 divide-y divide-gray-200/30 dark:divide-slate-700/30">
                        @foreach (var d in Model.Lessons)
                        {
                            var progressPercentage = d.TopicCount > 0 ? (d.CompletedCount * 100) / d.TopicCount : 0;
                            
                            var (icon, colorClass, bgClass) = d.Name.ToLower() switch
                            {
                                var name when name.Contains("türkçe") => ("bi-translate", "text-blue-600 dark:text-blue-400", "from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30"),
                                var name when name.Contains("matematik") => ("bi-calculator", "text-purple-600 dark:text-purple-400", "from-purple-100 to-purple-200 dark:from-purple-900/30 dark:to-purple-800/30"),
                                var name when name.Contains("tarih") => ("bi-clock-history", "text-orange-600 dark:text-orange-400", "from-orange-100 to-orange-200 dark:from-orange-900/30 dark:to-orange-800/30"),
                                var name when name.Contains("coğrafya") => ("bi-geo-alt", "text-green-600 dark:text-green-400", "from-green-100 to-green-200 dark:from-green-900/30 dark:to-green-800/30"),
                                var name when name.Contains("vatandaşlık") => ("bi-shield-check", "text-red-600 dark:text-red-400", "from-red-100 to-red-200 dark:from-red-900/30 dark:to-red-800/30"),
                                var name when name.Contains("güncel") => ("bi-newspaper", "text-indigo-600 dark:text-indigo-400", "from-indigo-100 to-indigo-200 dark:from-indigo-900/30 dark:to-indigo-800/30"),
                                _ => ("bi-book", "text-gray-600 dark:text-gray-400", "from-gray-100 to-gray-200 dark:from-gray-900/30 dark:to-gray-800/30")
                            };
                            
                            <tr class="hover:bg-white/70 dark:hover:bg-slate-700/70 transition-all duration-200">
                                <td class="px-6 py-6 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="w-12 h-12 bg-gradient-to-r @bgClass rounded-xl flex items-center justify-center mr-4 shadow-lg">
                                            <i class="@icon @colorClass text-lg"></i>
                                        </div>
                                        <div>
                                            <div class="text-sm font-semibold text-gray-900 dark:text-white">@d.Name</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-sm font-bold bg-gradient-to-r from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30 text-blue-800 dark:text-blue-300 shadow-lg">
                                        @d.TopicCount
                                    </span>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-sm font-bold bg-gradient-to-r from-green-100 to-green-200 dark:from-green-900/30 dark:to-green-800/30 text-green-800 dark:text-green-300 shadow-lg">
                                        @d.CompletedCount
                                    </span>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <div class="flex items-center justify-center">
                                        <div class="w-24 bg-gray-200 dark:bg-gray-600 rounded-full h-3 mr-3 shadow-inner">
                                            <div class="bg-gradient-to-r from-emerald-500 to-teal-500 h-3 rounded-full transition-all duration-500" style="width: @progressPercentage%"></div>
                                        </div>
                                        <span class="text-sm font-bold text-gray-700 dark:text-gray-300">%@progressPercentage</span>
                                    </div>
                                </td>
                                <td class="px-6 py-6 whitespace-nowrap text-center">
                                    <div class="flex justify-center space-x-2">
                                        @if (Model.IsAdmin)
                                        {
                                        <a href="/Lessons/Edit/@d.Id" class="group p-2 bg-gradient-to-r from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30 hover:from-blue-200 hover:to-blue-300 dark:hover:from-blue-800/50 dark:hover:to-blue-700/50 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" title="Düzenle">
                                            <i class="bi bi-pencil-fill text-blue-600 dark:text-blue-400 group-hover:scale-110 transition-transform"></i>
                                        </a>
                                        }
                                        <a href="/Lessons/Details/@d.Id" class="group p-2 bg-gradient-to-r from-green-100 to-green-200 dark:from-green-900/30 dark:to-green-800/30 hover:from-green-200 hover:to-green-300 dark:hover:from-green-800/50 dark:hover:to-green-700/50 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" title="Detayları Görüntüle">
                                            <i class="bi bi-eye-fill text-green-600 dark:text-green-400 group-hover:scale-110 transition-transform"></i>
                                        </a>
                                        @if (Model.IsAdmin)
                                        {
                                        <a href="/Lessons/Delete/@d.Id" class="group p-2 bg-gradient-to-r from-red-100 to-red-200 dark:from-red-900/30 dark:to-red-800/30 hover:from-red-200 hover:to-red-300 dark:hover:from-red-800/50 dark:hover:to-red-700/50 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" title="Sil">
                                            <i class="bi bi-trash-fill text-red-600 dark:text-red-400 group-hover:scale-110 transition-transform"></i>
                                        </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Card View -->
            <div class="lg:hidden p-4 space-y-4">
                @foreach (var d in Model.Lessons)
                {
                    var progressPercentage = d.TopicCount > 0 ? (d.CompletedCount * 100) / d.TopicCount : 0;
                    
                    var (icon, colorClass, bgClass) = d.Name.ToLower() switch
                    {
                        var name when name.Contains("türkçe") => ("bi-translate", "text-blue-600 dark:text-blue-400", "from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30"),
                        var name when name.Contains("matematik") => ("bi-calculator", "text-purple-600 dark:text-purple-400", "from-purple-100 to-purple-200 dark:from-purple-900/30 dark:to-purple-800/30"),
                        var name when name.Contains("tarih") => ("bi-clock-history", "text-orange-600 dark:text-orange-400", "from-orange-100 to-orange-200 dark:from-orange-900/30 dark:to-orange-800/30"),
                        var name when name.Contains("coğrafya") => ("bi-geo-alt", "text-green-600 dark:text-green-400", "from-green-100 to-green-200 dark:from-green-900/30 dark:to-green-800/30"),
                        var name when name.Contains("vatandaşlık") => ("bi-shield-check", "text-red-600 dark:text-red-400", "from-red-100 to-red-200 dark:from-red-900/30 dark:to-red-800/30"),
                        var name when name.Contains("güncel") => ("bi-newspaper", "text-indigo-600 dark:text-indigo-400", "from-indigo-100 to-indigo-200 dark:from-indigo-900/30 dark:to-indigo-800/30"),
                        _ => ("bi-book", "text-gray-600 dark:text-gray-400", "from-gray-100 to-gray-200 dark:from-gray-900/30 dark:to-gray-800/30")
                    };

                    <div class="bg-white/70 dark:bg-slate-700/70 rounded-2xl p-5 shadow-lg hover:shadow-xl transition-all duration-200">
                        <!-- Header -->
                        <div class="flex items-center mb-4">
                            <div class="w-14 h-14 bg-gradient-to-r @bgClass rounded-xl flex items-center justify-center mr-4 shadow-lg flex-shrink-0">
                                <i class="@icon @colorClass text-xl"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <h3 class="text-lg font-bold text-gray-900 dark:text-white truncate">@d.Name</h3>
                            </div>
                        </div>

                        <!-- Stats -->
                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <div class="bg-blue-50 dark:bg-blue-900/30 rounded-xl p-3 text-center">
                                <div class="text-xs text-blue-600 dark:text-blue-400 font-semibold mb-1">Toplam Konu</div>
                                <div class="text-2xl font-bold text-blue-800 dark:text-blue-300">@d.TopicCount</div>
                            </div>
                            <div class="bg-green-50 dark:bg-green-900/30 rounded-xl p-3 text-center">
                                <div class="text-xs text-green-600 dark:text-green-400 font-semibold mb-1">Tamamlanan</div>
                                <div class="text-2xl font-bold text-green-800 dark:text-green-300">@d.CompletedCount</div>
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        <div class="mb-4">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">İlerleme</span>
                                <span class="text-sm font-bold text-emerald-600 dark:text-emerald-400">%@progressPercentage</span>
                            </div>
                            <div class="w-full bg-gray-200 dark:bg-gray-600 rounded-full h-3 shadow-inner">
                                <div class="bg-gradient-to-r from-emerald-500 to-teal-500 h-3 rounded-full transition-all duration-500" style="width: @progressPercentage%"></div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-2">
                            @if (Model.IsAdmin)
                            {
                            <a href="/Lessons/Edit/@d.Id" class="flex-1 flex items-center justify-center gap-2 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl font-semibold transition-all shadow-lg active:scale-95">
                                <i class="bi bi-pencil-fill"></i>
                                <span class="text-sm">Düzenle</span>
                            </a>
                            }
                            <a href="/Lessons/Details/@d.Id" class="flex-1 flex items-center justify-center gap-2 py-3 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white rounded-xl font-semibold transition-all shadow-lg active:scale-95">
                                <i class="bi bi-eye-fill"></i>
                                <span class="text-sm">Görüntüle</span>
                            </a>
                            @if (Model.IsAdmin)
                            {
                            <a href="/Lessons/Delete/@d.Id" class="flex items-center justify-center px-4 py-3 bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white rounded-xl font-semibold transition-all shadow-lg active:scale-95">
                                <i class="bi bi-trash-fill text-lg"></i>
                            </a>
                            }
                        </div>
                    </div>
                }
            </div>
        
            @if (!Model.Lessons.Any())
            {
                <div class="text-center py-16">
                    <div class="w-24 h-24 bg-gradient-to-r from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-700 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <i class="bi bi-book text-gray-400 dark:text-gray-500 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Henüz ders eklenmemiş</h3>
                    <p class="text-gray-500 dark:text-gray-400 mb-6 max-w-md mx-auto">İlk dersinizi ekleyerek KPSS hazırlık sürecinizi organize etmeye başlayın</p>
                    @if (Model.IsAdmin)
                    {
                    <a href="/Lessons/Create" class="group inline-flex items-center px-6 py-3 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white rounded-xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                        <i class="bi bi-plus-circle-fill mr-2 group-hover:scale-110 transition-transform"></i>İlk Dersi Ekle
                    </a>
                    }
                </div>
            }
        </div>
    </div>
</div>