@page
@model KPSSStudyTracker.Pages.Lessons.CreateModel
@{
    ViewData["Title"] = "Yeni Ders";
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
            <i class="bi bi-plus-circle-fill text-primary-600 mr-2"></i>Yeni Ders Ekle
        </h1>
        <p class="text-gray-600 dark:text-gray-400">KPSS için yeni bir ders oluşturun</p>
    </div>

    <!-- Form -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <form method="post" class="space-y-6">
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Ders Adı <span class="text-red-500">*</span>
                </label>
                <input asp-for="Input.Name" 
                       class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-gray-700 dark:text-white" 
                       placeholder="Örn: Genel Kültür, Genel Yetenek, Eğitim Bilimleri" />
                <span asp-validation-for="Input.Name" class="text-red-500 text-sm"></span>
            </div>
            
            <div class="flex justify-end space-x-3 pt-4">
                <a href="/Lessons" class="px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                    <i class="bi bi-x-circle mr-2"></i>İptal
                </a>
                <button type="submit" class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors">
                    <i class="bi bi-check-circle mr-2"></i>Kaydet
                </button>
            </div>
        </form>
    </div>
</div>