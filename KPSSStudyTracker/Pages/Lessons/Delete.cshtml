@page "{id:int}"
@model KPSSStudyTracker.Pages.Lessons.DeleteModel
@{
    ViewData["Title"] = "Ders Sil";
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="text-center mb-8">
        <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-red-100 dark:bg-red-900 mb-4">
            <i class="bi bi-exclamation-triangle-fill text-red-600 dark:text-red-400 text-2xl"></i>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
            Ders Silme Onayı
        </h1>
        <p class="text-gray-600 dark:text-gray-400">
            Bu işlem geri alınamaz. Lütfen dikkatli olun.
        </p>
    </div>

    <!-- Warning Card -->
    <div class="bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-xl p-6 mb-8">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <i class="bi bi-exclamation-triangle-fill text-red-600 dark:text-red-400 text-xl"></i>
            </div>
            <div class="ml-3">
                <h3 class="text-lg font-medium text-red-800 dark:text-red-200">
                    Dikkat!
                </h3>
                <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                    <p>Bu dersi silmek aşağıdaki verileri de kalıcı olarak silecektir:</p>
                    <ul class="list-disc list-inside mt-2 space-y-1">
                        <li>Tüm konular (@Model.TopicCount konu)</li>
                        <li>Konu ilerleme verileri</li>
                        <li>Soru çözüm istatistikleri</li>
                        <li>Notlar ve kaynak bilgileri</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Lesson Info Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-8">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
            <i class="bi bi-book-fill text-blue-600 mr-2"></i>Silinecek Ders Bilgileri
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
                <div class="bg-blue-50 dark:bg-blue-900 rounded-lg p-4">
                    <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">@Model.LessonName</div>
                    <div class="text-sm text-blue-600 dark:text-blue-400 mt-1">Ders Adı</div>
                </div>
            </div>
            
            <div class="text-center">
                <div class="bg-green-50 dark:bg-green-900 rounded-lg p-4">
                    <div class="text-2xl font-bold text-green-600 dark:text-green-400">@Model.TopicCount</div>
                    <div class="text-sm text-green-600 dark:text-green-400 mt-1">Toplam Konu</div>
                </div>
            </div>
            
            <div class="text-center">
                <div class="bg-purple-50 dark:bg-purple-900 rounded-lg p-4">
                    <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">@Model.CompletedTopicCount</div>
                    <div class="text-sm text-purple-600 dark:text-purple-400 mt-1">Tamamlanan Konu</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <form method="post" class="space-y-4">
            <input type="hidden" asp-for="Id" />
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a asp-page="Index" 
                   class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
                    <i class="bi bi-arrow-left-circle mr-2"></i>
                    İptal Et
                </a>
                
                <button type="submit" 
                        class="inline-flex items-center justify-center px-6 py-3 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors"
                        onclick="return confirm('Bu dersi ve tüm konularını kalıcı olarak silmek istediğinizden emin misiniz?')">
                    <i class="bi bi-trash-fill mr-2"></i>
                    Evet, Dersi Sil
                </button>
            </div>
        </form>
    </div>

    <!-- Additional Warning -->
    <div class="mt-6 text-center">
        <p class="text-sm text-gray-500 dark:text-gray-400">
            <i class="bi bi-info-circle mr-1"></i>
            Bu işlem geri alınamaz. Emin değilseniz "İptal Et" butonuna tıklayın.
        </p>
    </div>
</div>

