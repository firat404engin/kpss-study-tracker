@page
@model KPSSStudyTracker.Pages.HealthModel
@{
    ViewData["Title"] = "Health Check";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Health Check - KPSS Study Tracker</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #1a1a2e; color: #eee; padding: 40px; }
        .container { max-width: 800px; margin: 0 auto; background: #16213e; padding: 30px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        h1 { color: #4ecca3; border-bottom: 3px solid #4ecca3; padding-bottom: 10px; }
        .status { padding: 15px; margin: 15px 0; border-radius: 5px; font-size: 18px; }
        .success { background: #155724; border-left: 5px solid #28a745; }
        .error { background: #721c24; border-left: 5px solid #dc3545; }
        .info { background: #0c5460; border-left: 5px solid #17a2b8; padding: 10px; margin: 10px 0; }
        .count { display: inline-block; background: #4ecca3; color: #16213e; padding: 5px 15px; border-radius: 20px; font-weight: bold; margin: 5px; }
        pre { background: #0f0f23; padding: 15px; border-radius: 5px; overflow-x: auto; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🏥 Health Check</h1>
        
        <div class="status @(string.IsNullOrEmpty(Model.ErrorMessage) ? "success" : "error")">
            @Model.Status
        </div>

        <div class="status @(string.IsNullOrEmpty(Model.ErrorMessage) ? "success" : "error")">
            @Model.DatabaseStatus
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="status error">
                <strong>❌ Hata Detayı:</strong><br/>
                <pre>@Model.ErrorMessage</pre>
            </div>
        }

        @if (string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="info">
                <strong>📊 Veritabanı İstatistikleri:</strong><br/>
                <span class="count">👥 Kullanıcı: @Model.UserCount</span>
                <span class="count">📚 Ders: @Model.LessonCount</span>
                <span class="count">📖 Konu: @Model.TopicCount</span>
            </div>
        }

        <div class="info">
            <strong>🔗 Connection String:</strong><br/>
            <pre>@Model.ConnectionString</pre>
        </div>

        <div style="margin-top: 30px; text-align: center;">
            <a href="/Account/Login" style="color: #4ecca3; text-decoration: none; font-size: 18px;">← Giriş Sayfasına Dön</a>
        </div>
    </div>
</body>
</html>
