@page
@model KPSSStudyTracker.Pages.Statistics.IndexModel
@{
    ViewData["Title"] = "İstatistikler";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
                    <i class="bi bi-graph-up text-primary-600 mr-2"></i>İstatistikler
                </h1>
                <p class="text-gray-600 dark:text-gray-400">Çalışma performansınızı analiz edin</p>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400">
                Son güncelleme: @DateTime.Now.ToString("dd MMMM yyyy")
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mr-4">
                    <i class="bi bi-question-circle-fill text-blue-600 text-xl"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Toplam Çözülen Soru</p>
                    <p class="text-2xl font-bold text-blue-600">@Model.TotalQuestionsSolved</p>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mr-4">
                    <i class="bi bi-check-circle-fill text-green-600 text-xl"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Genel Doğruluk</p>
                    <p class="text-2xl font-bold text-green-600">%@Model.OverallAccuracy</p>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mr-4">
                    <i class="bi bi-bookmark-check-fill text-purple-600 text-xl"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Konu Tamamlama</p>
                    <p class="text-2xl font-bold text-purple-600">%@Model.CompletionRate</p>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900 rounded-lg flex items-center justify-center mr-4">
                    <i class="bi bi-trophy-fill text-yellow-600 text-xl"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Ortalama Net Skor</p>
                    <p class="text-2xl font-bold text-yellow-600">@Model.AverageNetScore</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 1 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Correct/Wrong Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center mb-4">
                <i class="bi bi-bar-chart-fill text-primary-600 text-xl mr-2"></i>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Ders Bazlı Doğru / Yanlış Dağılımı</h3>
            </div>
            <div class="h-80">
                <canvas id="cwChart"></canvas>
            </div>
        </div>

        <!-- Completion Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center mb-4">
                <i class="bi bi-pie-chart-fill text-green-600 text-xl mr-2"></i>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Konu Tamamlama Oranları</h3>
            </div>
            <div class="h-80">
                <canvas id="compChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <!-- Progress Chart -->
        <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center mb-4">
                <i class="bi bi-graph-up text-blue-600 text-xl mr-2"></i>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Deneme Sınavı İlerlemesi</h3>
            </div>
            <div class="h-80">
                <canvas id="progressChart"></canvas>
            </div>
        </div>

        <!-- Weak Topics -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center mb-4">
                <i class="bi bi-exclamation-triangle-fill text-red-600 text-xl mr-2"></i>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Geliştirilmesi Gereken Konular</h3>
            </div>
            @if (Model.WeakTopics.Any())
            {
                <div class="space-y-3">
                    @for (int i = 0; i < Model.WeakTopics.Count; i++)
                    {
                        <div class="flex items-center p-3 bg-red-50 dark:bg-red-900 rounded-lg">
                            <span class="w-6 h-6 bg-red-500 text-white text-xs font-bold rounded-full flex items-center justify-center mr-3">@(i + 1)</span>
                            <span class="text-sm text-red-700 dark:text-red-300">@Model.WeakTopics[i]</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8">
                    <i class="bi bi-check-circle-fill text-green-500 text-4xl mb-3"></i>
                    <p class="text-green-600 dark:text-green-400 font-medium">Tüm konular başarılı!</p>
                </div>
            }
        </div>
    </div>

    <!-- Detailed Statistics -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex items-center mb-6">
            <i class="bi bi-list-ul text-gray-600 dark:text-gray-400 text-xl mr-2"></i>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Detaylı İstatistikler</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
                <h4 class="text-md font-semibold text-primary-600 mb-4">Konu İstatistikleri</h4>
                <div class="space-y-3">
                    <div class="flex justify-between items-center py-2 border-b border-gray-200 dark:border-gray-700">
                        <span class="text-gray-600 dark:text-gray-400">Toplam Konu:</span>
                        <span class="font-semibold text-gray-900 dark:text-white">@Model.TotalTopics</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-gray-200 dark:border-gray-700">
                        <span class="text-gray-600 dark:text-gray-400">Tamamlanan Konu:</span>
                        <span class="font-semibold text-green-600">@Model.TotalTopicsCompleted</span>
                    </div>
                    <div class="flex justify-between items-center py-2">
                        <span class="text-gray-600 dark:text-gray-400">Kalan Konu:</span>
                        <span class="font-semibold text-yellow-600">@(Model.TotalTopics - Model.TotalTopicsCompleted)</span>
                    </div>
                </div>
            </div>
            <div>
                <h4 class="text-md font-semibold text-primary-600 mb-4">Soru İstatistikleri</h4>
                <div class="space-y-3">
                    <div class="flex justify-between items-center py-2 border-b border-gray-200 dark:border-gray-700">
                        <span class="text-gray-600 dark:text-gray-400">Toplam Çözülen:</span>
                        <span class="font-semibold text-gray-900 dark:text-white">@Model.TotalQuestionsSolved</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-gray-200 dark:border-gray-700">
                        <span class="text-gray-600 dark:text-gray-400">Genel Doğruluk:</span>
                        <span class="font-semibold text-green-600">%@Model.OverallAccuracy</span>
                    </div>
                    <div class="flex justify-between items-center py-2">
                        <span class="text-gray-600 dark:text-gray-400">Ortalama Net Skor:</span>
                        <span class="font-semibold text-blue-600">@Model.AverageNetScore</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Chart data
    const labels = @Html.Raw(Model.LessonLabelsJson);
    const correct = @Html.Raw(Model.CorrectJson);
    const wrong = @Html.Raw(Model.WrongJson);
    const compLabels = @Html.Raw(Model.CompletionLabelsJson);
    const compData = @Html.Raw(Model.CompletionDataJson);
    const progressLabels = @Html.Raw(Model.NetProgressLabelsJson);
    const progressData = @Html.Raw(Model.NetProgressDataJson);

    // Chart configurations
    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom',
                labels: {
                    usePointStyle: true,
                    padding: 20,
                    color: 'rgb(107, 114, 128)'
                }
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                grid: {
                    color: 'rgba(0, 0, 0, 0.1)'
                },
                ticks: {
                    color: 'rgb(107, 114, 128)'
                }
            },
            x: {
                grid: {
                    display: false
                },
                ticks: {
                    color: 'rgb(107, 114, 128)'
                }
            }
        }
    };

    // Doğru/Yanlış Chart
    const cwCtx = document.getElementById('cwChart');
    if (cwCtx) {
        new Chart(cwCtx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Doğru',
                        data: correct,
                        backgroundColor: 'rgba(59, 130, 246, 0.8)',
                        borderColor: 'rgba(59, 130, 246, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Yanlış',
                        data: wrong,
                        backgroundColor: 'rgba(239, 68, 68, 0.8)',
                        borderColor: 'rgba(239, 68, 68, 1)',
                        borderWidth: 1
                    }
                ]
            },
            options: chartOptions
        });
    }

    // Tamamlama Chart
    const compCtx = document.getElementById('compChart');
    if (compCtx) {
        new Chart(compCtx, {
            type: 'doughnut',
            data: {
                labels: compLabels,
                datasets: [{
                    data: compData,
                    backgroundColor: [
                        'rgba(34, 197, 94, 0.8)',
                        'rgba(59, 130, 246, 0.8)',
                        'rgba(168, 85, 247, 0.8)',
                        'rgba(239, 68, 68, 0.8)',
                        'rgba(107, 114, 128, 0.8)'
                    ],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            padding: 20,
                            color: 'rgb(107, 114, 128)'
                        }
                    }
                }
            }
        });
    }

    // İlerleme Chart
    const progressCtx = document.getElementById('progressChart');
    if (progressCtx) {
        new Chart(progressCtx, {
            type: 'line',
            data: {
                labels: progressLabels,
                datasets: [{
                    label: 'Net Skor',
                    data: progressData,
                    borderColor: 'rgba(59, 130, 246, 1)',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: 'rgba(59, 130, 246, 1)',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(0, 0, 0, 0.1)'
                        },
                        ticks: {
                            color: 'rgb(107, 114, 128)'
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            color: 'rgb(107, 114, 128)'
                        }
                    }
                }
            }
        });
    }
</script>